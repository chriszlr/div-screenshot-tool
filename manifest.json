{
  "manifest_version": 3,
  "name": "Div Screenshot Tool",
  "version": "1.0.0",
  "description": "Capture individual elements, the visible viewport, or an entire page as screenshots.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "downloads",
    "tabs"
  ],
  "commands": {
    "start-picker": {
      "description": "Start the screenshot picker"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Div Screenshot Tool",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
